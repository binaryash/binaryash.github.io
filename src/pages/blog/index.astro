---
import { BLOGS_PER_PAGE, getAllBlogs } from "../../lib/blogIndex";
import SiteNavbar from "../../components/SiteNavbar.astro";

const allBlogs = await getAllBlogs();
const totalPages = Math.max(1, Math.ceil(allBlogs.length / BLOGS_PER_PAGE));
const currentPage = 1;
const items = allBlogs.slice(0, BLOGS_PER_PAGE);
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Blog</title>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const initial = saved || (systemDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", initial);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <style is:global>
      @font-face {
        font-family: "Virgil";
        src: url("/fonts/Virgil.woff2") format("woff2"), local("Virgil");
        font-display: swap;
      }

      :root {
        --bg: #efefef;
        --ink: #252525;
      }

      html[data-theme="dark"] {
        --bg: #1f2125;
        --ink: #d7d9dd;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 1.25rem;
        background: var(--bg);
        color: var(--ink);
        font-family: "Virgil", "Comic Sans MS", cursive;
        transition: background-color 220ms ease, color 220ms ease;
      }

      a {
        color: inherit;
      }

      .frame {
        min-height: 94vh;
        display: flex;
        flex-direction: column;
        padding: 2rem 0 3rem;
      }

      .nav-wrap {
        max-width: 560px;
        margin: 0 auto 3rem;
        animation: fade-up 420ms ease both;
      }

      .nav {
        border: 0;
        padding: 0.8rem 1rem 0.8rem 0.45rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .nav a,
      .nav a:visited,
      .nav a:hover,
      .nav a:active {
        color: inherit;
        text-decoration: none;
      }

      .brand {
        margin-left: -0.6rem;
        font-weight: 400;
        text-decoration: none;
      }

      .menu {
        display: flex;
        gap: 1.2rem;
        align-items: center;
      }

      .menu a {
        color: inherit;
        text-decoration: none;
        transition: transform 180ms ease, opacity 180ms ease;
      }

      .menu a:hover {
        opacity: 0.75;
        transform: translateY(-1px);
      }

      .theme-btn {
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        padding: 0;
        cursor: pointer;
        transition: transform 180ms ease, opacity 180ms ease;
      }

      .theme-btn:hover {
        opacity: 0.75;
        transform: translateY(-1px);
      }

      .list {
        max-width: 560px;
        margin: 2.4rem auto 0;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        animation: fade-up 480ms ease both;
        animation-delay: 80ms;
      }

      .item {
        display: block;
        margin: 0;
        padding: 0.45rem 0;
        font-size: 1.2rem;
        line-height: 1.45;
        text-decoration: none;
      }

      .pager {
        margin-top: auto;
        padding: 3.2rem 0 1rem;
        text-align: center;
        font-size: 1.2rem;
        animation: fade-up 480ms ease both;
        animation-delay: 140ms;
      }

      .pager a {
        opacity: 0.8;
      }

      .snack-toggle {
        display: none;
        border: 0;
        background: transparent;
        padding: 0.1rem 0;
        cursor: pointer;
      }

      .snack-icon {
        display: flex;
        flex-direction: column;
        gap: 9px;
      }

      .snack-icon span {
        width: 90px;
        height: 4px;
        border-radius: 999px;
        background: var(--ink);
      }

      .mobile-panel {
        margin-top: 0.8rem;
        border: 0;
        padding: 0.8rem 1rem;
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        pointer-events: none;
        transform: translateY(-4px);
        transition:
          max-height 240ms ease,
          opacity 180ms ease,
          transform 220ms ease;
      }

      .mobile-panel a,
      .mobile-panel button {
        display: block;
        margin: 0 0 0.6rem;
        color: inherit;
        text-decoration: none;
        font: inherit;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
      }

      .mobile-panel button {
        margin: 0;
      }

      .nav-wrap[data-open="true"] .mobile-panel {
        max-height: 220px;
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 720px) {
        .frame {
          padding: 1.2rem 0 2rem;
        }

        .nav-wrap {
          margin-bottom: 2rem;
        }

        .menu {
          display: none;
        }

        .theme-btn.desktop {
          display: none;
        }

        .snack-toggle {
          display: block;
        }

        .item {
          font-size: 1.08rem;
        }

        .pager {
          font-size: 1.05rem;
        }
      }
    </style>
  </head>
  <body>
    <main class="frame">
      <SiteNavbar brand="binaryash" />

      <section class="list">
        {items.map((item) => <a class="item" href={`/blog/${item.slug}`}>{item.title}</a>)}
      </section>

      <footer class="pager">
        {currentPage > 1 && <a href={currentPage === 2 ? "/blog" : `/blog/page/${currentPage - 1}`}>prev</a>}
        {currentPage > 1 && " "}
        <span>page {currentPage}/{totalPages}</span>
        {currentPage < totalPages && " "}
        {currentPage < totalPages && <a href={`/blog/page/${currentPage + 1}`}>next</a>}
      </footer>
    </main>

    <script is:inline>
      const root = document.documentElement;
      const toggles = () => document.querySelectorAll("[data-theme-toggle]");
      const snackToggle = document.getElementById("snack-toggle");
      const navWrap = document.getElementById("nav-wrap");

      const setTheme = (theme) => {
        root.setAttribute("data-theme", theme);
        try {
          localStorage.setItem("theme", theme);
        } catch {}
        toggles().forEach((btn) => {
          btn.textContent = `theme: ${theme === "dark" ? "Light" : "Dark"}`;
        });
      };

      setTheme(root.getAttribute("data-theme") || "light");
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const button = target.closest("[data-theme-toggle]");
        if (!button) return;
        setTheme((root.getAttribute("data-theme") || "light") === "dark" ? "light" : "dark");
      });

      snackToggle?.addEventListener("click", () => {
        const open = navWrap?.dataset.open === "true";
        const next = !open;
        if (navWrap) navWrap.dataset.open = String(next);
        snackToggle.setAttribute("aria-expanded", String(next));
      });
    </script>
  </body>
</html>
