---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import BlogCard from '@/components/BlogCard.astro';
import { config } from '@/data/config';
---
<BaseLayout currentView="blog" title="Notes | Binary Ash">
  <div class="animate-in fade-in duration-700 py-12 md:py-20 max-w-2xl" data-motion-reveal>
    <div class="flex items-center gap-4 mb-12">
      <h1 class="text-4xl font-serif font-medium text-neutral-900 dark:text-neutral-100">Notes</h1>
      <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800 mt-2"></div>
    </div>
    <div class="flex flex-col">
      {config.blog.map((post) => <BlogCard post={post} />)}
    </div>
  </div>
  <Footer />
</BaseLayout>
