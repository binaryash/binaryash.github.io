---
import { readdir, readFile, stat } from "node:fs/promises";
import { join } from "node:path";
import SiteNavbar from "../components/SiteNavbar.astro";

const contentRoot = join(process.cwd(), "public", "content");
const projectRoot = join(contentRoot, "projects");
const blogRoot = join(contentRoot, "blog");
const bioPath = join(contentRoot, "profile", "bio.md");

const toTitle = (slug: string) =>
  slug
    .replace(".md", "")
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const cleanLine = (line: string) =>
  line
    .replace(/^#+\s*/, "")
    .replace(/\*\*/g, "")
    .replace(/`/g, "")
    .replace(/^\*\s*/, "")
    .trim();

const readExcerpt = async (filePath: string, fallback: string) => {
  try {
    const raw = await readFile(filePath, "utf-8");
    const lines = raw
      .split("\n")
      .map((line) => cleanLine(line))
      .filter((line) => line && !line.startsWith("!"));
    return lines.find((line) => !line.startsWith("#")) ?? lines[0] ?? fallback;
  } catch {
    return fallback;
  }
};

const bio = await readExcerpt(
  bioPath,
  "I build software and AI systems from idea to deployment."
);

const projectFiles = (await readdir(projectRoot)).filter((file) =>
  file.endsWith(".md")
);

const projectsWithMeta = await Promise.all(
  projectFiles.map(async (file) => {
    const fullPath = join(projectRoot, file);
    const fileStat = await stat(fullPath);
    const slug = file.replace(".md", "");
    const words = slug.split("-").filter((word) => word.length > 2);
    return {
      file,
      slug,
      title: toTitle(file),
      tags: words.slice(0, 2).join(", "),
      about: await readExcerpt(fullPath, "Simple project summary."),
      mtime: fileStat.mtimeMs,
    };
  })
);

const projects = projectsWithMeta
  .sort((a, b) => b.mtime - a.mtime)
  .slice(0, 4);

const blogFiles = (await readdir(blogRoot)).filter((file) => file.endsWith(".md"));

const blogWithMeta = await Promise.all(
  blogFiles.map(async (file) => {
    const fullPath = join(blogRoot, file);
    const fileStat = await stat(fullPath);
    return {
      slug: file.replace(".md", ""),
      title: toTitle(file),
      summary: await readExcerpt(fullPath, "Short blog note."),
      mtime: fileStat.mtimeMs,
    };
  })
);

const recentBlog = blogWithMeta.sort((a, b) => b.mtime - a.mtime)[0];
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="binaryash portfolio: projects, blog, and engineering work."
    />
    <title>BinaryAsh</title>
    <script is:inline>
      (() => {
        const readStoredTheme = () => {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        };

        try {
          const saved = readStoredTheme();
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const initial = saved || (systemDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", initial);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <style is:global>
      @font-face {
        font-family: "Virgil";
        src: url("/fonts/Virgil.woff2") format("woff2"), local("Virgil");
        font-display: swap;
      }

      :root {
        --bg: #efefef;
        --ink: #252525;
        --card: transparent;
        --stroke: 1px;
      }

      html[data-theme="dark"] {
        --bg: #1f2125;
        --ink: #d7d9dd;
        --card: transparent;
      }

      body {
        margin: 0;
        padding: 1.25rem;
        background: var(--bg);
        color: var(--ink);
        font-family: "Virgil", "Comic Sans MS", cursive;
        transition: background-color 220ms ease, color 220ms ease;
      }

      a {
        color: inherit;
      }

      * {
        box-sizing: border-box;
      }

      .frame {
        padding: 2rem 0 3rem;
        min-height: 94vh;
      }

      .nav-wrap {
        max-width: 560px;
        margin: 0 auto 3rem;
        animation: fade-up 420ms ease both;
      }

      .nav {
        border: 0;
        padding: 0.8rem 1rem 0.8rem 0.45rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .menu {
        display: flex;
        gap: 1.2rem;
        align-items: center;
      }

      .brand {
        margin-left: -0.6rem;
        font-weight: 400;
        text-decoration: none;
      }

      .menu a {
        color: inherit;
        text-decoration: none;
        transition: transform 180ms ease, opacity 180ms ease;
      }

      .menu a:hover {
        opacity: 0.75;
        transform: translateY(-1px);
      }

      .theme-btn {
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        padding: 0;
        cursor: pointer;
        transition: transform 180ms ease, opacity 180ms ease;
      }

      .theme-btn:hover {
        opacity: 0.75;
        transform: translateY(-1px);
      }

      .snack-toggle {
        display: none;
        border: 0;
        background: transparent;
        padding: 0.1rem 0;
        cursor: pointer;
      }

      .snack-icon {
        display: flex;
        flex-direction: column;
        gap: 9px;
      }

      .snack-icon span {
        width: 90px;
        height: 4px;
        border-radius: 999px;
        background: var(--ink);
      }

      .mobile-panel {
        margin-top: 0.8rem;
        border: 0;
        padding: 0.8rem 1rem;
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        pointer-events: none;
        transform: translateY(-4px);
        transition:
          max-height 240ms ease,
          opacity 180ms ease,
          transform 220ms ease;
      }

      .mobile-panel a,
      .mobile-panel button {
        display: block;
        margin: 0 0 0.6rem;
        color: inherit;
        text-decoration: none;
        font: inherit;
        background: transparent;
        border: 0;
        padding: 0;
        cursor: pointer;
      }

      .mobile-panel button {
        margin: 0;
      }

      .nav-wrap[data-open="true"] .mobile-panel {
        max-height: 220px;
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }

      section {
        max-width: 560px;
        margin: 0 auto 2.6rem;
        animation: fade-up 480ms ease both;
      }

      section:nth-of-type(1) {
        animation-delay: 60ms;
      }

      section:nth-of-type(2) {
        animation-delay: 120ms;
      }

      section:nth-of-type(3) {
        animation-delay: 180ms;
      }

      section:nth-of-type(4) {
        animation-delay: 220ms;
      }

      p {
        margin: 0 0 0.7rem;
        line-height: 1.45;
      }

      h2 {
        margin: 0 0 0.9rem;
        font-size: 1.2rem;
        font-weight: 500;
      }

      .grid {
        max-width: 560px;
        margin: 0 auto 3.6rem;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        column-gap: 1.2rem;
        row-gap: 1rem;
      }

      .card {
        border: 0;
        border-radius: 0;
        padding: 1.1rem 1.2rem 1rem;
        background: var(--card);
        transition: transform 200ms ease;
        animation: fade-up 460ms ease both;
        position: relative;
        overflow: clip;
      }

      .card-link {
        color: inherit;
        text-decoration: none;
        display: block;
      }

      .card:hover {
        transform: translateY(-2px);
      }

      .rough-frame {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      .card-content {
        position: relative;
        z-index: 1;
      }

      .card:nth-child(1) {
        animation-delay: 140ms;
      }

      .card:nth-child(2) {
        animation-delay: 180ms;
      }

      .card:nth-child(3) {
        animation-delay: 220ms;
      }

      .card:nth-child(4) {
        animation-delay: 260ms;
      }

      .row {
        display: flex;
        justify-content: space-between;
        gap: 0.6rem;
        margin-bottom: 0.4rem;
      }

      .muted {
        opacity: 0.85;
      }

      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }

      @media (max-width: 720px) {
        .frame {
          padding: 1.2rem 0 2rem;
        }

        .nav-wrap {
          margin-bottom: 2rem;
        }

        .menu {
          display: none;
        }

        .theme-btn.desktop {
          display: none;
        }

        .snack-toggle {
          display: block;
        }

        .grid {
          grid-template-columns: 1fr;
        }

      }
    </style>
  </head>
  <body>
    <main class="frame">
      <SiteNavbar brand="binaryash" />

      <section id="about">
        <p>BinaryAsh</p>
        <p>What I do</p>
        <p class="muted">{bio}</p>
      </section>

      <section id="projects" class="grid">
        {
          projects.map((project) => (
            <a class="card-link" href={`/projects/${project.slug}`}>
              <article class="card">
                <div class="card-content">
                  <div class="row">
                    <span>{project.title}</span>
                    <span class="muted">{project.tags || "build, code"}</span>
                  </div>
                  <p class="muted">{project.about}</p>
                </div>
              </article>
            </a>
          ))
        }
      </section>

      <section id="blog">
        <h2>Blog</h2>
        {
          recentBlog ? (
            <a class="card-link" href={`/blog/${recentBlog.slug}`}>
              <p>{recentBlog.title}</p>
              <p class="muted">{recentBlog.summary}</p>
            </a>
          ) : (
            <>
              <p>Most recent blog post</p>
              <p class="muted">Short update from my notes.</p>
            </>
          )
        }
      </section>

      <section>
        <h2>Socials</h2>
        <p>You can contact me by email.</p>
      </section>
    </main>
    <script is:inline>
      const root = document.documentElement;
      const toggles = () => document.querySelectorAll("[data-theme-toggle]");
      const snackToggle = document.getElementById("snack-toggle");
      const navWrap = document.getElementById("nav-wrap");
      const initial = root.getAttribute("data-theme") || "light";
      const persistTheme = (theme) => {
        try {
          localStorage.setItem("theme", theme);
        } catch {
          // Ignore storage errors; theme switch should still work for this session.
        }
      };

      const setTheme = (theme) => {
        root.setAttribute("data-theme", theme);
        persistTheme(theme);
        toggles().forEach((btn) => {
          btn.textContent = `theme: ${theme === "dark" ? "Light" : "Dark"}`;
        });
      };

      setTheme(initial);
      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const button = target.closest("[data-theme-toggle]");
        if (!button) return;
        const next =
          (root.getAttribute("data-theme") || "light") === "dark"
            ? "light"
            : "dark";
        setTheme(next);
      });

      snackToggle?.addEventListener("click", () => {
        const open = navWrap?.dataset.open === "true";
        const next = !open;
        if (navWrap) navWrap.dataset.open = String(next);
        snackToggle.setAttribute("aria-expanded", String(next));
      });
    </script>
    <script is:inline>
      const loadRough = () =>
        new Promise((resolve, reject) => {
          if (window.rough) return resolve(window.rough);
          const script = document.createElement("script");
          script.src = "/vendor/rough.js";
          script.async = true;
          script.onload = () => resolve(window.rough);
          script.onerror = reject;
          document.head.appendChild(script);
        });

      const initRoughFrames = () => {
        const cards = Array.from(document.querySelectorAll(".card"));
        if (!cards.length || !window.rough) return;

        const roundedRectPath = (x, y, w, h, r) => {
          const rr = Math.max(0, Math.min(r, w / 2, h / 2));
          return [
            `M ${x + rr} ${y}`,
            `L ${x + w - rr} ${y}`,
            `Q ${x + w} ${y} ${x + w} ${y + rr}`,
            `L ${x + w} ${y + h - rr}`,
            `Q ${x + w} ${y + h} ${x + w - rr} ${y + h}`,
            `L ${x + rr} ${y + h}`,
            `Q ${x} ${y + h} ${x} ${y + h - rr}`,
            `L ${x} ${y + rr}`,
            `Q ${x} ${y} ${x + rr} ${y}`,
            "Z",
          ].join(" ");
        };

        const drawCard = (card, seed) => {
          card.querySelectorAll(".rough-frame").forEach((el) => el.remove());
          const width = Math.max(0, card.clientWidth - 2);
          const height = Math.max(0, card.clientHeight - 2);
          if (!width || !height) return;

          const stroke = getComputedStyle(document.documentElement)
            .getPropertyValue("--ink")
            .trim();
          const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
          svg.setAttribute("class", "rough-frame");
          svg.setAttribute("viewBox", `0 0 ${width} ${height}`);
          svg.setAttribute("preserveAspectRatio", "none");
          svg.setAttribute("aria-hidden", "true");

          const rc = window.rough.svg(svg);
          const first = rc.path(roundedRectPath(2, 2, width - 4, height - 4, 26), {
            seed,
            stroke,
            strokeWidth: 0.68,
            roughness: 1.9,
            bowing: 1.8,
            fill: "transparent",
            fillStyle: "solid",
            preserveVertices: true,
            disableMultiStroke: false,
          });
          const second = rc.path(roundedRectPath(4, 3, width - 8, height - 7, 22), {
            seed: seed + 11,
            stroke,
            strokeWidth: 0.42,
            roughness: 1.6,
            bowing: 1.5,
            fill: "transparent",
            fillStyle: "solid",
            preserveVertices: true,
            disableMultiStroke: false,
          });
          svg.appendChild(first);
          svg.appendChild(second);
          card.appendChild(svg);
        };

        cards.forEach((card, index) => drawCard(card, 100 + index * 17));
        const ro = new ResizeObserver(() => {
          cards.forEach((card, index) => drawCard(card, 100 + index * 17));
        });
        cards.forEach((card) => ro.observe(card));
        const observer = new MutationObserver(() => {
          cards.forEach((card, index) => drawCard(card, 100 + index * 17));
        });
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["data-theme"],
        });
      };

      const scheduleInit = () => {
        const start = () => loadRough().then(initRoughFrames).catch(() => {});
        if ("requestIdleCallback" in window) {
          window.requestIdleCallback(start, { timeout: 1200 });
        } else {
          setTimeout(start, 60);
        }
      };
      scheduleInit();
    </script>
  </body>
</html>
