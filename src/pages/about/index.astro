---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import SocialButton from '@/components/SocialButton.astro';
import MarkdownContent from '@/components/MarkdownContent.astro';
import Icon from '@/components/Icon.astro';
import AsciiSignature from '@/components/AsciiSignature.astro';
import { config } from '@/data/config';
---
<BaseLayout currentView="about" title="About | Binary Ash">
  <div class="animate-in fade-in duration-700 py-12 md:py-20 max-w-2xl">
    <h1 class="text-4xl font-serif font-medium text-neutral-900 dark:text-neutral-100 mb-8">About</h1>

    <div class="prose prose-lg prose-neutral dark:prose-invert text-neutral-500 dark:text-neutral-400 leading-relaxed mb-12" data-motion-reveal>
      <MarkdownContent contentFile={config.profile.bioFile} />
    </div>

    <div class="mb-12 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 p-4" data-motion-reveal>
      <AsciiSignature />
    </div>

    <div class="mb-12" data-motion-reveal>
      <h3 class="text-sm font-medium text-neutral-900 dark:text-neutral-100 mb-4 uppercase tracking-wider">Skills &amp; Tools</h3>
      <div class="flex flex-wrap gap-2">
        {config.profile.skills.map((skill) => (
          <span class="px-3 py-1 rounded-full bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 text-sm border border-neutral-100 dark:border-neutral-800">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <div class="border-t border-neutral-200 dark:border-neutral-800 pt-8" data-motion-reveal>
      <h3 class="text-sm font-medium text-neutral-900 dark:text-neutral-100 mb-4 uppercase tracking-wider">Connect</h3>
      <div class="flex gap-4">
        {config.profile.socials.map((social) => <SocialButton social={social} />)}
        <a
          href={`mailto:${config.profile.email}`}
          class="p-2 rounded-full bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-neutral-500 dark:text-neutral-400 hover:border-accent dark:hover:border-accent hover:text-accent dark:hover:text-accent hover:scale-105 transition-all duration-300"
          title="Send Email"
        >
          <Icon name="Mail" size={18} strokeWidth={1.5} />
        </a>
      </div>
    </div>
  </div>
  <Footer />
</BaseLayout>
