---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { config } from '@/data/config';
---
<BaseLayout currentView="projects" title="Projects | Binary Ash">
  <div class="animate-in fade-in duration-700 py-12 md:py-20" data-motion-reveal>
    <div class="flex items-center gap-4 mb-12">
      <h1 class="text-4xl font-serif font-medium text-neutral-900 dark:text-neutral-100">All Projects</h1>
      <div class="h-px flex-1 bg-neutral-200 dark:bg-neutral-800 mt-2"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12">
      {config.projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
  <Footer />
</BaseLayout>
