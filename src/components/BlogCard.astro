---
import type { BlogPost } from '@/data/types';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---
<a href={`/blog/${post.id}/`} class="group cursor-pointer py-6 border-b border-neutral-100 dark:border-neutral-800 last:border-0 block" data-motion-list>
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-3 text-xs text-neutral-400 dark:text-neutral-500 font-mono mb-1">
      <span>{post.date}</span>
      <span>•</span>
      <span>{post.readTime}</span>
    </div>
    <h3 class="text-xl font-medium text-neutral-900 dark:text-neutral-100 group-hover:text-accent transition-colors">
      {post.title}
    </h3>
    <p class="text-neutral-500 dark:text-neutral-400 leading-relaxed line-clamp-2">
      {post.excerpt}
    </p>
    <div class="flex gap-2 mt-2">
      {post.tags.map((tag) => (
        <span class="text-xs text-neutral-400 dark:text-neutral-600">#{tag}</span>
      ))}
    </div>
  </div>
</a>
