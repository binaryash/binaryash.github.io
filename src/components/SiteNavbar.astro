---
type Props = {
  brand?: string;
};

const { brand = "binaryash" } = Astro.props;
---

<div class="site-navbar nav-wrap" id="nav-wrap">
  <nav class="nav">
    <a class="brand" href="/">{brand}</a>
    <div class="menu">
      <a href="/projects">projects</a>
      <a href="/blog">blog</a>
      <a href="/#about">about</a>
      <button class="theme-btn desktop" type="button" data-theme-toggle>theme</button>
    </div>
    <button
      id="snack-toggle"
      class="snack-toggle"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="snack-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </nav>
  <div class="mobile-panel">
    <a href="/projects">projects</a>
    <a href="/blog">blog</a>
    <a href="/#about">about</a>
    <button type="button" data-theme-toggle>theme</button>
  </div>
</div>

<style is:global>
  .site-navbar.nav-wrap {
    max-width: 560px !important;
    width: min(560px, calc(100% - 2.5rem)) !important;
    margin: 0 auto 3rem !important;
    animation: fade-up 420ms ease both;
  }

  .site-navbar .nav {
    border: 0;
    padding: 0.8rem 1rem 0.8rem 0.45rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .site-navbar .brand {
    margin-left: -0.6rem;
    font-weight: 400;
    color: inherit;
    text-decoration: none;
  }

  .site-navbar .menu {
    display: flex;
    gap: 1.2rem;
    align-items: center;
  }

  .site-navbar .nav a,
  .site-navbar .nav a:visited,
  .site-navbar .nav a:hover,
  .site-navbar .nav a:active {
    color: inherit;
    text-decoration: none;
  }

  .site-navbar .menu a {
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .site-navbar .menu a:hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }

  .site-navbar .theme-btn {
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    padding: 0;
    cursor: pointer;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .site-navbar .theme-btn:hover {
    opacity: 0.75;
    transform: translateY(-1px);
  }

  .site-navbar .snack-toggle {
    display: none;
    border: 0;
    background: transparent;
    padding: 0.1rem 0;
    cursor: pointer;
  }

  .site-navbar .snack-icon {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .site-navbar .snack-icon span {
    width: 90px;
    height: 4px;
    border-radius: 999px;
    background: var(--ink);
  }

  .site-navbar .mobile-panel {
    margin-top: 0.8rem;
    border: 0;
    padding: 0.8rem 1rem;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transform: translateY(-4px);
    transition:
      max-height 240ms ease,
      opacity 180ms ease,
      transform 220ms ease;
  }

  .site-navbar .mobile-panel a,
  .site-navbar .mobile-panel button {
    display: block;
    margin: 0 0 0.6rem;
    color: inherit;
    text-decoration: none;
    font: inherit;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
  }

  .site-navbar .mobile-panel button {
    margin: 0;
  }

  .site-navbar.nav-wrap[data-open="true"] .mobile-panel {
    max-height: 220px;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  @media (max-width: 720px) {
    .site-navbar.nav-wrap {
      margin-bottom: 2rem;
    }

    .site-navbar .menu {
      display: none;
    }

    .site-navbar .theme-btn.desktop {
      display: none;
    }

    .site-navbar .snack-toggle {
      display: block;
    }
  }
</style>
